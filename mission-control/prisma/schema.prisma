generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#3B82F6")
  emoji       String   @default("📦")
  status      String   @default("active")
  createdAt   DateTime @default(now())

  tasks            Task[]
  content          ContentItem[]
  alerts           Alert[]
  metrics          MetricSnapshot[]
  agentAssignments AgentAssignment[]
  workflows        Workflow[]
  kpiSnapshots     KpiSnapshot[]
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  type         String
  status       String   @default("idle")
  currentTask  String?
  lastActiveAt DateTime @default(now())
  config       String   @default("{}")

  agentAssignments AgentAssignment[]
  tasks            Task[]
  contentItems     ContentItem[]
  activityLogs     ActivityLog[]
  memories         AgentMemory[]
}

model AgentAssignment {
  id         String   @id @default(cuid())
  agentId    String
  projectId  String
  agent      Agent    @relation(fields: [agentId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])
  role       String   @default("contributor")
  assignedAt DateTime @default(now())

  @@unique([agentId, projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  projectId   String?
  agentId     String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  project Project? @relation(fields: [projectId], references: [id])
  agent   Agent?   @relation(fields: [agentId], references: [id])
}

model ContentItem {
  id           String    @id @default(cuid())
  title        String
  platform     String
  type         String    @default("post")
  status       String    @default("draft")
  scheduledFor DateTime?
  publishedAt  DateTime?
  publishedUrl String?
  metricsJson  String    @default("{}")
  projectId    String?
  agentId      String?
  createdAt    DateTime  @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  agent   Agent?   @relation(fields: [agentId], references: [id])
}

model Alert {
  id             String    @id @default(cuid())
  severity       String
  source         String    @default("system")
  message        String
  status         String    @default("new")
  projectId      String?
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  project Project? @relation(fields: [projectId], references: [id])
}

model MetricSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  platform  String
  metric    String
  value     Float
  metadata  String   @default("{}")
  projectId String?

  project Project? @relation(fields: [projectId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  agentId   String?
  action    String
  target    String?
  result    String?
  projectId String?
  timestamp DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id])
}

model Workflow {
  id            String   @id @default(cuid())
  name          String
  description   String?
  triggerType   String   @default("manual")
  triggerConfig String   @default("{}")
  steps         String   @default("[]")
  status        String   @default("draft")
  projectId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project?      @relation(fields: [projectId], references: [id])
  runs    WorkflowRun[]
}

model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id])
  status      String    @default("pending")
  currentStep Int       @default(0)
  totalSteps  Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  triggerData String    @default("{}")
  stepResults String    @default("[]")
  error       String?
  createdAt   DateTime  @default(now())

  logs WorkflowLog[]
}

model WorkflowLog {
  id        String      @id @default(cuid())
  runId     String
  run       WorkflowRun @relation(fields: [runId], references: [id])
  stepIndex Int         @default(-1)
  stepType  String      @default("system")
  message   String
  level     String      @default("info")
  createdAt DateTime    @default(now())
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  permissions String    @default("read")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  active      Boolean   @default(true)
}

model ChannelCredential {
  id          String    @id @default(cuid())
  channelId   String    @unique
  enabled     Boolean   @default(false)
  credentials String    @default("{}")
  defaults    String    @default("{}")
  testedAt    DateTime?
  testResult  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AgentMemory {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  type      String
  key       String
  value     String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([agentId, type, key])
}

model KpiSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  projectId String?
  source    String
  metric    String
  value     Float
  delta     Float?
  metadata  String   @default("{}")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, metric, date])
}

model ContentCalendar {
  id             String    @id @default(cuid())
  projectId      String?
  channelIds     String    @default("[]")
  title          String
  body           String
  contentType    String    @default("short_post")
  status         String    @default("draft")
  scheduledFor   DateTime?
  publishedAt    DateTime?
  publishResults String    @default("{}")
  workflowRunId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ApprovalRequest {
  id            String    @id @default(cuid())
  workflowRunId String?
  contentId     String?
  type          String    @default("content")
  title         String
  preview       String
  status        String    @default("pending")
  approvalCode  String    @unique
  telegramMsgId String?
  expiresAt     DateTime
  respondedAt   DateTime?
  respondedBy   String?
  createdAt     DateTime  @default(now())
}
